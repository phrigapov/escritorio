# GitHub API (para integração de repositório e GitHub Projects)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_OWNER=phrigapov
GITHUB_REPO=escritorio
GITHUB_ORG=sismacke
GITHUB_PROJECT_NUMBER=1

# GitHub OAuth (para autenticação - qualquer usuário do GitHub)
# Crie um OAuth App em: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Para produção, atualize para:
# GITHUB_REDIRECT_URI=https://seu-dominio.com/api/auth/callback

# Nota: O GITHUB_TOKEN precisa ter permissões de:
# - read:project (para ler dados do projeto)
# - repo (para ler issues e commits)
